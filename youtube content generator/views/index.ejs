
<%- include('./partials/header.ejs') %>

<div class="container-fluid px-2 px-md-4 px-lg-5 py-3 d-flex flex-column">

  <!-- TOP SECTION -->
  <div class="top-section">

    <h1 class="text-center mb-4">🎬 NicheForge</h1>

    <form action="/generate" method="POST">
      <div class="row justify-content-center mb-4">
        <div class="col-12 col-md-8 col-lg-6">
          <div class="input-group">
            <input type="text" class="form-control" name="niche" placeholder="Enter niche..." required>
            <button class="btn btn-primary" type="submit">Generate</button>
          </div>
        </div>
      </div>
    </form>

  </div>

 <% if (locals.data){  %> 
  <div id="output" class="row g-3">

    <div class="col-12 col-lg-4">
      <div class="card h-100 position-relative"> 
        <button class="copy-btn" onclick='copyText("<%= data.channel_name %>", this)'>Copy</button>
        <div class="card-body">
          <h6><i class="fa-regular fa-compass me-2"></i> Channel Name</h6>
          <% for (let i = 0 ; i < (data.channel_name).length ; i++){ %>
            <p><%= data.channel_name[i] %></p>
          <% } %>
        </div>
      </div>
    </div>

    <div class="col-12 col-lg-4">
      <div class="card h-100 position-relative">
        <button class="copy-btn" onclick='copyText("<%= data.channel_description %>", this)'>Copy</button>
        <div class="card-body">
          <h6><i class="fa-regular fa-address-card me-2"></i> Channel Bio</h6>
          <p><%= data.channel_description %></p>
        </div>
      </div>
    </div>

    <div class="col-12 col-lg-4">
      <div class="card h-100 position-relative">
        <button class="copy-btn" onclick='copyText("<%= data.logo_prompt %>", this)'>Copy</button>
        <div class="card-body">
          <h6><i class="fa-regular fa-image me-2"></i> Logo Prompt</h6>
          <p><%= data.logo_prompt %></p>
        </div>
      </div>
    </div>

    <div class="col-12 col-lg-4">
      <div class="card h-100 position-relative">
        <button class="copy-btn" onclick='copyText("<%= data.banner_prompt %>", this)'>Copy</button>
        <div class="card-body">
          <h6><i class="fa-regular fa-rectangle-ad me-2"></i> Banner Prompt</h6>
          <p><%= data.banner_prompt %></p>
        </div>
      </div>
    </div>

    <div class="col-12 col-lg-4">
      <div class="card h-100 position-relative">
        <button class="copy-btn" onclick='copyText("<%= data.video_captions %>", this)'>Copy</button>
        <div class="card-body">
          <h6><i class="fa-regular fa-closed-captioning me-2"></i> Captions</h6>
          <div>
             <% for (let i = 0 ; i < (data.video_captions).length ; i++){ %>
            <p><%= data.video_captions[i] %></p>
          <% } %>
          </div>
        </div>
      </div>
    </div>

    <div class="col-12 col-lg-4">
      <div class="card h-100 position-relative">
        <button class="copy-btn" onclick='copyText("<%= data.video_description %>", this)'>Copy</button>
        <div class="card-body">
          <h6><i class="fa-regular fa-file-lines me-2"></i> Description</h6>
          <p><%= data.video_description %></p>
        </div>
      </div>
    </div>

    <div class="col-12">
      <div class="card position-relative">
        <button class="copy-btn" onclick='copyText("<%= data.tags %>", this)'>Copy</button>
        <div class="card-body">
          <h6><i class="fa-solid fa-hashtag me-2"></i> Tags</h6>
          <div class="tags">

            <% for (let i = 0 ; i < (data.tags).length ; i++){ %>
            <span> #<%= data.tags[i] %></span>
          <% } %>
            
          </div>
        </div>
      </div>
    </div>

  </div>

  <% } else { %> 

  <!-- EMPTY STATE -->
  <div class="flex-grow-1 d-flex   justify-content-center text-center">
    <div>
      <h4 class="mt-3">Start creating your channel</h4>
      <p class="text-muted mb-4">
        Enter a niche and generate names, bio, tags, and more
      </p>
      <div class="text-muted" style="font-size: 14px;">
        cooking • tech • fitness • travel • gaming
      </div>
    </div>

  </div>

  <% } %> 

</div>

<%- include('./partials/footer.ejs') %>
